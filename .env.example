# App
APP_ENV=dev
DATABASE_URL=postgresql://knowledgehub:knowledgehub@postgres:5432/knowledgehub
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini-2025-08-07
EVALUATION_MODEL=gpt-4.1-nano-2025-04-14
EMBEDDING_MODEL=text-embedding-3-large
TEMPERATURE=1

# Free model
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cohere (optional reranking)
COHERE_API_KEY=your_cohere_api_key
COHERE_RERANK_MODEL=rerank-v3.5

# CLIP image embedding
CLIP_MODEL_NAME=clip-ViT-B-32

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_kb
QDRANT_IMAGE_COLLECTION=rag_image_kb

# Retrieval / RAG
RETRIEVAL_TOP_K=12
IMAGE_RETRIEVAL_TOP_K=8
RERANK_TOP_K=4
QUERY_EXPANSION_COUNT=2
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_MAX_PER_SOURCE=3
EVALUATION_MAX_ROWS=100

# Ingestion
CHUNK_SIZE=500
CHUNK_OVERLAP=100
DOCUMENT_IMAGE_MIN_DIMENSION=32
DOCUMENT_IMAGE_MIN_BYTES=2048
DOCUMENT_IMAGE_DESCRIPTION_WORKERS=4
MAX_UPLOAD_SIZE_MB=30
